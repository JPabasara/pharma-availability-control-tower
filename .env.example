# MySQL Docker Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_DATABASE=control_tower_mvp
MYSQL_USER=ct_user
MYSQL_PASSWORD=ct_pass
MYSQL_ROOT_PASSWORD=rootpass

# SQLAlchemy Database URL
DATABASE_URL=mysql+pymysql://ct_user:ct_pass@localhost:3307/control_tower_mvp?charset=utf8mb4

# Engine Mode: "stub" uses deterministic stubs, "real" uses actual M1/M2/M3 engines
ENGINE_MODE=stub

# Per-engine mode overrides (stub|real)
# If set, these take priority over ENGINE_MODE for the specific engine.
M1_ENGINE_MODE=stub
M2_ENGINE_MODE=stub
M3_ENGINE_MODE=stub
